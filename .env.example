# .env.example
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# DO NOT commit .env to version control — it is already listed in .gitignore.

# =============================================================================
# Database
# =============================================================================

# Full PostgreSQL connection URL.
# When set, this takes priority over the individual DB_* variables below.
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=

# Individual DB connection parameters — used only when DATABASE_URL is not set.
DB_HOST=localhost
DB_PORT=5432
DB_USER=marketview
DB_PASSWORD=marketview
DB_NAME=marketview

# =============================================================================
# DhanHQ (live stock price data)
# =============================================================================

# Access token and client ID from the DhanHQ developer portal (https://dhanhq.co).
DHANQ_API_KEY=
DHANQ_CLIENT_ID=

# =============================================================================
# PDF Parser service
# =============================================================================

# Base URL of the Python PDF parser service.
# Default: http://localhost:5001
# In Docker Compose this is set to http://pdf-parser:5001 automatically.
PARSER_URL=http://localhost:5001

# =============================================================================
# Frontend (Next.js)
# =============================================================================

# Backend API base URL used by the Next.js reverse proxy (next.config.js).
# In Docker Compose this is set to http://backend:8080 automatically.
# For local dev without Docker, point to the running Go backend.
BACKEND_URL=http://localhost:8080

# Browser-accessible backend URL (prefixed NEXT_PUBLIC_ so it is inlined at build time).
# Must be reachable from the user's browser, not just the Next.js server.
NEXT_PUBLIC_API_URL=http://localhost:8080

# =============================================================================
# Screenshot / E2E tooling (dev only)
# =============================================================================

# Base URL used by the screenshot script (npm run screenshot).
# Defaults to http://localhost:3001 if not set.
BASE_URL=http://localhost:3001

# Set to "1" to start Docker Compose before taking screenshots and stop it after.
# START_SERVER=1
# STOP_SERVER=1

# Set to "1" for verbose screenshot script output.
# VERBOSE=1
