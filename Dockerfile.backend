# Stage 1: build
FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY go.mod ./
RUN go mod download

COPY . .
RUN go build -o marketview ./main.go

# Stage 2: minimal runtime image
FROM alpine:3.19

RUN adduser -D -g '' appuser
WORKDIR /app

COPY --from=builder /app/marketview .

USER appuser

EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget -qO- http://localhost:8080/api/indicators || exit 1

CMD ["./marketview"]
